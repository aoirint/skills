name: Set up locked .NET environment
description: Install the reviewed SDK and restore the committed NuGet graph.

runs:
  using: composite
  steps:
    - name: Set up .NET
      uses: actions/setup-dotnet@c2fa09f4bde5ebb9d1777cf28262a3eb3db3ced7 # v5.2.0
      with:
        global-json-file: global.json
        cache: true
        cache-dependency-path: @@PROJECT_DIRECTORY@@/packages.lock.json

    - name: Restore NuGet packages
      shell: bash
      run: dotnet restore --locked-mode

    - name: Verify selected SDK
      shell: bash
      run: dotnet --version
